#pragma once

// =============================================================================
// WiFi & Security Credentials — TEMPLATE
// =============================================================================
//
// To use this file:
//   1. Copy it to "wifi_credentials.h" in the same directory
//   2. Replace the placeholder values with your actual credentials
//   3. "wifi_credentials.h" is git-ignored so your secrets stay safe
//
// The ESP32 will try each WiFi network in order. If none connect,
// it starts a captive portal (AP named "BadmintonTimerSetup") so you
// can configure WiFi from your phone.

// =============================================================================
// Security Settings
// =============================================================================

// OTA (Over-the-Air) Update Password
// Change this to a strong, unique password to protect against
// unauthorized firmware updates over the network.
const char* OTA_PASSWORD = "YourStrongOTAPassword";

// WebSocket Authentication Password (leave empty to use built-in user management)
const char* WEB_PASSWORD = "";

// =============================================================================
// WiFi Network Credentials
// =============================================================================

struct WiFiCredential {
    const char* ssid;
    const char* password;
};

// Add your club's WiFi networks here. The ESP32 tries each one in order.
// Put the most reliable network first.
const WiFiCredential known_networks[] = {
    {"YourClubWiFi", "YourClubPassword"},       // Primary — club network
    {"YourHomeWiFi", "YourHomePassword"},        // Secondary — for development
    // {"OpenNetwork", ""}                       // Use empty string for open networks
};

const size_t known_networks_count = sizeof(known_networks) / sizeof(WiFiCredential);
